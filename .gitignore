# Terraform state files
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/

# Dependency lock file
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# Crash log files
crash.log
crash.*.log

# Sensitive variable files — all tfvars are excluded by default.
# Add explicit !exceptions below for any checked-in example tfvars.
*.tfvars.json

# macOS
.DS_Store
